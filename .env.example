# === ZORUNLU ===
FOOTBALL_DATA_API_KEY=xxx   # football-data.org → geçmiş maçlar + fikstür
ODDS_API_KEY=xxx            # the-odds-api.com → gerçek bahis oranları

# === OPSİYONEL ===
APIFOOTBALL_KEY=xxx         # api-sports.io → gerçek xG + sakatlık verisi
RAPIDAPI_XG_KEY=xxx         # rapidapi.com/Wolf1984/api/football-xg-statistics → ExpectedScore xG
ODDSPAPI_KEY=xxx            # oddspapi.io (free: 1000 istek/ay) → gerçek Pinnacle opening/closing

# === LOG SEVİYESİ (varsayılan: INFO) ===
LOG_LEVEL=INFO
